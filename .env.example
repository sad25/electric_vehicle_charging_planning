# Bu dosyayı .env olarak kopyalayın ve kendi anahtarlarınızı girin.
# .env ASLA git'e gönderilmez (.gitignore'da).

# Google Maps Platform anahtarı. Directions API ve Elevation API etkin olmalı.
# https://console.cloud.google.com  (faturalandırma gerekir)
GOOGLE_MAPS_API_KEY=buraya-google-maps-anahtariniz

# Open Charge Map API anahtarı (ücretsiz)
# https://openchargemap.org  > giriş > My Apps > Register an application
OCM_API_KEY=buraya-ocm-anahtariniz
